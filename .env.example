# Create a bot in @BotFather and paste the token here.
TELEGRAM_BOT_TOKEN=

# Target channel/group where normalized vacancies are published.
# Examples: @your_channel_username or -1001234567890
TARGET_CHAT_ID=

# Optional comma-separated Telegram user IDs allowed to publish via this bot.
# Leave empty during first local setup; set for production channel safety.
OPERATOR_USER_IDS=

# normalize = parse forwarded/user messages into the IT Job Board card
# copy = copy the original incoming message to TARGET_CHAT_ID
FORWARDED_MODE=normalize

# Optional SQLite database path for deduplication.
DATABASE_PATH=data/vacancies.sqlite3

# Source polling interval while `tg-vacancy-bot run` is active.
# Set to 0 to disable background polling and only handle forwarded messages.
SOURCE_POLL_INTERVAL_SECONDS=900

# Prevent first-run floods from API/RSS sources. Set 0 for unlimited.
SOURCE_MAX_PUBLISH_PER_POLL=20

# Translate and compress vacancy descriptions before publishing normalized cards.
# Requires a real OpenAI API key. Leave false to publish parsed descriptions as-is.
LOCALIZE_DESCRIPTIONS=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Optional OpenAI-compatible endpoint, for example OpenRouter:
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_BASE_URL=

# Optional source toggles for the source polling command.
ENABLE_REMOTIVE=true
ENABLE_ARBEITNOW=true
ENABLE_REMOTEOK=true
ENABLE_HN_WHO_IS_HIRING=true

# Optional API keys.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=us
ADZUNA_QUERY=software developer
ADZUNA_LOCATION=

JOOBLE_API_KEY=
JOOBLE_KEYWORDS=software developer
JOOBLE_LOCATION=
