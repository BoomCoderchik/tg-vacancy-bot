# Create a bot in @BotFather and paste the token here.
TELEGRAM_BOT_TOKEN=

# Target channel/group where vacancy cards are published.
# Examples: @your_channel_username or -1001234567890
TARGET_CHAT_ID=

# Optional comma-separated Telegram user IDs allowed to publish via this bot.
OPERATOR_USER_IDS=

# normalize = parse forwarded/user messages into the IT Job Board card
# copy = copy the original incoming message to TARGET_CHAT_ID
FORWARDED_MODE=normalize

# Form filling is limited to explicitly approved domains. Arbeitnow has the
# current real adapter; it fills the form but never sends it automatically.
APPLICATION_ALLOWED_DOMAINS=arbeitnow.com

# Optional SQLite database path for deduplication.
DATABASE_PATH=data/vacancies.sqlite3

# Source polling interval while `tg-vacancy-bot run` is active.
# Set to 0 to disable background polling and only handle forwarded messages.
SOURCE_POLL_INTERVAL_SECONDS=60
SOURCE_MAX_PUBLISH_PER_POLL=20
SOURCE_MAX_AGE_HOURS=48

# The only automatic source: its public API and application form do not require
# an account. Set false to disable automatic source polling completely.
ENABLE_ARBEITNOW=true

# Optional LinkedIn hiring-post discovery. The adapters read only publicly
# indexed posts; account login, CAPTCHA bypass, and automatic application are
# not supported.
ENABLE_LINKEDIN_POST_SEARCH=false
SERPAPI_API_KEY=
SERPER_API_KEY=
LINKEDIN_POST_SEARCH_QUERY=(site:linkedin.com/posts OR site:linkedin.com/feed/update) ("we are hiring" OR hiring OR "ищем" OR "ищет") (frontend OR backend OR developer OR engineer OR react OR python OR разработчик OR инженер)
LINKEDIN_POST_SEARCH_RESULTS_WANTED=10
ENABLE_LINKEDIN_POST_SCRAPER=false
LINKEDIN_POST_SCRAPER_QUERY=(site:linkedin.com/posts OR site:linkedin.com/feed/update) ("we are hiring" OR hiring OR "ищем" OR "ищет") (frontend OR backend OR developer OR engineer OR react OR python OR разработчик OR инженер)
LINKEDIN_POST_SCRAPER_SEARCH_PROVIDERS=duckduckgo,bing
LINKEDIN_POST_SCRAPER_RESULTS_WANTED=100
ENABLE_LINKEDIN_POST_HEADLESS=false
LINKEDIN_POST_HEADLESS_QUERY=(site:linkedin.com/posts OR site:linkedin.com/feed/update) ("we are hiring" OR hiring OR "ищем" OR "ищет") (frontend OR backend OR developer OR engineer OR react OR python OR разработчик OR инженер)
LINKEDIN_POST_HEADLESS_RESULTS_WANTED=10
LINKEDIN_POST_HEADLESS_TIMEOUT_SECONDS=20
LINKEDIN_POST_MAX_AGE_HOURS=120

# Optional manual-message localization. Source polling never calls a model.
LOCALIZE_DESCRIPTIONS=false
LOCALIZATION_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_FALLBACK_MODELS=
OPENAI_BASE_URL=
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_FALLBACK_MODELS=openai/gpt-oss-20b
