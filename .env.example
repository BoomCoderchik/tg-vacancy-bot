# Create a bot in @BotFather and paste the token here.
TELEGRAM_BOT_TOKEN=

# Target channel/group where normalized vacancies are published.
# Examples: @your_channel_username or -1001234567890
TARGET_CHAT_ID=

# Optional comma-separated Telegram user IDs allowed to publish via this bot.
# Leave empty during first local setup; set for production channel safety.
OPERATOR_USER_IDS=

# normalize = parse forwarded/user messages into the IT Job Board card
# copy = copy the original incoming message to TARGET_CHAT_ID
FORWARDED_MODE=normalize

# Optional SQLite database path for deduplication.
DATABASE_PATH=data/vacancies.sqlite3

# Source polling interval while `tg-vacancy-bot run` is active.
# Set to 0 to disable background polling and only handle forwarded messages.
# 60 seconds is near-real-time polling for APIs that do not provide webhooks.
SOURCE_POLL_INTERVAL_SECONDS=60

# Prevent first-run floods from API/RSS sources. Set 0 for unlimited.
SOURCE_MAX_PUBLISH_PER_POLL=20

# Publish dated source vacancies only while they are still fresh.
# Undated vacancies are not dropped automatically.
SOURCE_MAX_AGE_HOURS=48

# Translate and compress vacancy descriptions before publishing normalized cards.
# Requires a real provider API key. Leave false to publish parsed descriptions as-is.
LOCALIZE_DESCRIPTIONS=false
# openai = OpenAI or any endpoint configured through OPENAI_BASE_URL.
# groq = Groq's free OpenAI-compatible translation configuration below.
LOCALIZATION_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Optional comma-separated model list tried before the built-in reliable translation fallback.
OPENAI_FALLBACK_MODELS=
# Optional OpenAI-compatible endpoint, for example OpenRouter:
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_BASE_URL=

# Groq free translation mode. Create an API key at https://console.groq.com/keys,
# then set LOCALIZATION_PROVIDER=groq and GROQ_API_KEY. Its default primary model
# has a high free request quota; GROQ_FALLBACK_MODELS is used when it is unavailable.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_FALLBACK_MODELS=openai/gpt-oss-20b

# Optional source toggles for the source polling command.
ENABLE_REMOTIVE=true
ENABLE_ARBEITNOW=true
ENABLE_REMOTEOK=true
ENABLE_HN_WHO_IS_HIRING=true
ENABLE_JOBICY=true
ENABLE_WE_WORK_REMOTELY=true
ENABLE_HIMALAYAS=true
ENABLE_REAL_WORK_FROM_ANYWHERE=true
ENABLE_JOBSCOLLIDER=true

# Optional LinkedIn hiring-post discovery through SerpApi or Serper Google Search.
# This finds public LinkedIn posts like "Ищем Junior Front-End Developer..."
# and publishes short snippet-based cards with the post link.
ENABLE_LINKEDIN_POST_SEARCH=false
SERPAPI_API_KEY=
# Alternative Google Search API provider. Set this instead of SERPAPI_API_KEY
# when using https://serper.dev/.
SERPER_API_KEY=
LINKEDIN_POST_SEARCH_QUERY=(site:linkedin.com/posts OR site:linkedin.com/feed/update) ("we are hiring" OR "we're hiring" OR hiring OR "looking for" OR "join our team" OR "open role" OR "ищем" OR "ищет" OR "нанимаем" OR "в команду") (frontend OR "front-end" OR backend OR fullstack OR "full-stack" OR "software developer" OR "software engineer" OR developer OR engineer OR react OR python OR designer OR "AI engineer" OR "ML engineer" OR "LLM engineer" OR разработчик OR инженер)
LINKEDIN_POST_SEARCH_LOCATION=Kazakhstan
LINKEDIN_POST_SEARCH_RESULTS_WANTED=10

# Optional free LinkedIn hiring-post discovery by scraping public search HTML.
# This does not need an API key, but it is less stable than keyed search APIs because
# search-result HTML can change or rate-limit automated requests.
ENABLE_LINKEDIN_POST_SCRAPER=false
# Separate fallback search queries with ||.
LINKEDIN_POST_SCRAPER_QUERY=(site:linkedin.com/posts OR site:linkedin.com/feed/update) ("we are hiring" OR "we're hiring" OR hiring) (frontend OR backend OR fullstack OR "software developer" OR "software engineer" OR react OR python) || (site:linkedin.com/posts OR site:linkedin.com/feed/update) ("looking for" OR "join our team" OR "open role") (developer OR engineer OR frontend OR backend OR fullstack OR react OR python) || (site:linkedin.com/posts OR site:linkedin.com/feed/update) ("ищем" OR "ищет" OR "нанимаем" OR "в команду") (разработчик OR инженер OR frontend OR backend OR fullstack OR react OR python)
LINKEDIN_POST_SCRAPER_LOCATION=Kazakhstan
# Comma-separated public HTML search providers. DuckDuckGo is tried first; Bing
# keeps the scraper useful when DuckDuckGo returns an anti-bot challenge.
LINKEDIN_POST_SCRAPER_SEARCH_PROVIDERS=duckduckgo,bing
LINKEDIN_POST_SCRAPER_RESULTS_WANTED=100
# Optional headless enrichment of public LinkedIn post pages. It finds post URLs
# through Bing, reads only public text without a LinkedIn login, and stops on
# login/CAPTCHA/2FA instead of trying to bypass it.
ENABLE_LINKEDIN_POST_HEADLESS=false
LINKEDIN_POST_HEADLESS_QUERY=(site:linkedin.com/posts OR site:linkedin.com/feed/update) ("we are hiring" OR "we're hiring" OR hiring OR "looking for" OR "ищем" OR "ищет" OR "нанимаем" OR "в команду") (frontend OR backend OR fullstack OR developer OR engineer OR react OR python OR разработчик OR инженер)
LINKEDIN_POST_HEADLESS_LOCATION=Kazakhstan
LINKEDIN_POST_HEADLESS_RESULTS_WANTED=10
LINKEDIN_POST_HEADLESS_TIMEOUT_SECONDS=20
LOCALIZATION_MAX_PER_POLL=12

# Optional API keys.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=us
ADZUNA_QUERY=software developer
ADZUNA_LOCATION=

JOOBLE_API_KEY=
JOOBLE_KEYWORDS=software developer
JOOBLE_LOCATION=
